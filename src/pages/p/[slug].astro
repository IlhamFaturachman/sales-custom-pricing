---
import { supabase } from '../../lib/supabase';
import pricingScripts from '../../data/_pricing-scripts.js?raw';
import headCss from '../../data/_template-head-css.html?raw';
import footerHtml from '../../data/_template-footer.html?raw';

const { slug } = Astro.params;

const { data: page, error } = await supabase
  .from('pricing_pages')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !page) {
  return Astro.redirect('/404');
}

const [categoriesResult, durationsResult, plansResult] = await Promise.all([
  supabase.from('pricing_categories').select('*').eq('pricing_page_id', page.id).order('sort_order'),
  supabase.from('pricing_durations').select('*').eq('pricing_page_id', page.id).order('sort_order'),
  supabase.from('pricing_plans').select('*').eq('pricing_page_id', page.id).order('sort_order'),
]);

const categories = categoriesResult.data || [];
const allDurations = durationsResult.data || [];
const plans = plansResult.data || [];

const planIds = plans.map(p => p.id);
const featuresResult = planIds.length > 0
  ? await supabase.from('pricing_features').select('*').in('pricing_plan_id', planIds).order('sort_order')
  : { data: [] };

const features = featuresResult.data || [];

const plansWithFeatures = plans.map(plan => ({
  ...plan,
  features: features.filter(f => f.pricing_plan_id === plan.id),
}));

// Derive durations per category from plans (only show durations that have plans)
const durationsByCategory: Record<string, any[]> = {};
categories.forEach(cat => {
  const catPlanDurationIds = new Set(
    plansWithFeatures
      .filter(p => p.pricing_category_id === cat.id)
      .map(p => p.pricing_duration_id)
  );
  durationsByCategory[cat.id] = allDurations
    .filter(d => catPlanDurationIds.has(d.id))
    .sort((a, b) => a.sort_order - b.sort_order);
});

// Group plans by category and duration
const plansByCategoryAndDuration: Record<string, Record<string, any[]>> = {};
categories.forEach(cat => {
  plansByCategoryAndDuration[cat.id] = {};
  durationsByCategory[cat.id].forEach(dur => {
    plansByCategoryAndDuration[cat.id][dur.id] = plansWithFeatures.filter(
      p => p.pricing_category_id === cat.id && p.pricing_duration_id === dur.id
    );
  });
});

const icons: Record<string, string> = {
  'omnichannel': '/_astro/omnichannel-active.5275cfd7.svg',
  'whatsapp': '/_astro/wa.973797de.svg',
  'wa': '/_astro/wa.973797de.svg',
  'system': '/_astro/system.9f773c00.svg',
  'maintenance': '/_astro/system.9f773c00.svg',
  'broadcast': '/_astro/brodcast.414c2162.svg',
  'chatbot': '/_astro/chatbot.bfd99bf8.svg',
};

function formatPrice(price: number | null): string {
  if (price === null) return 'Hubungi Kami';
  return 'Rp. ' + price.toLocaleString('id-ID');
}

function getCategoryIcon(cat: any): string {
  return icons[cat.category_icon?.toLowerCase()] || icons[cat.category_name?.toLowerCase()] || icons['system'];
}

function getGroupedFeatures(plan: any): Array<{category: string, feats: any[]}> {
  const grouped: Record<string, any[]> = {};
  (plan.features || []).forEach((f: any) => {
    if (!grouped[f.feature_category_name]) grouped[f.feature_category_name] = [];
    grouped[f.feature_category_name].push(f);
  });
  return Object.entries(grouped).map(([category, feats]) => ({ category, feats }));
}

const pricingScriptsStr = pricingScripts;
---
<html lang="id">
  <head>
    <style>
      html { background: #fff !important; scroll-behavior: smooth; }
      body {
        transition: opacity ease-in 0.2s;
        background: #fff;
      }
      body[unresolved] {
        opacity: 0;
        display: block;
        overflow: hidden;
        position: relative;
      }
    </style>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Pricing custom untuk ${page.company_name || page.client_name}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@100..800&display=swap" rel="stylesheet" />

    <title>{page.header_title}</title>
    <link rel="stylesheet" href="/_astro/index.f93530f0.css" />
    <link rel="stylesheet" href="/_astro/index.17256798.css" />
    <link rel="stylesheet" href="/_astro/index.2c480ef4.css" />
    <Fragment set:html={headCss} />
  </head>
  <body>
    <div id="default-layout">
      <div id="main-content">
        <div class="layout-container">
          <div class="content bg-white">
            <div class="py-4 md:py-10">
              <section id="price" class="mx-auto px-8 md:px-12">
                <div>
                  <div class="mx-auto max-w-7xl md:mb-4 px-8 md:px-12">
                    <h1 class="text-center text-[22px] font-extrabold text-slate-900 text-sm sm:text-base md:text-lg lg:text-5xl leading-snug">
                      {page.header_title}
                    </h1>
                    {page.valid_until && (
                      <p class="text-center text-sm text-gray-500 mt-4">
                        Berlaku sampai: {page.valid_until}
                      </p>
                    )}
                  </div>
                </div>
                <div>
                  <div class="hidden md:block">
                    <div class="mt-20 mb-10 flex justify-center pr-4 max-w-7xl mx-auto">
                      <div class="flex">
                        {categories.map((cat, i) => (
                          <button
                            type="button"
                            data-category-id={cat.id}
                            class={'category-tab px-6 py-4 transition-colors duration-150 ease-in-out ' + (i === 0 ? 'border-primary border-b-4' : 'border-b-4 border-neutral-300')}
                          >
                            <div class="flex gap-3 text-[22px] font-bold capitalize">
                              <img src={getCategoryIcon(cat)} alt="icon" />
                              <span class={'transition duration-150 ease-in-out ' + (i === 0 ? 'text-primary' : 'text-neutral-400')}>
                                {cat.category_name}
                              </span>
                            </div>
                          </button>
                        ))}
                      </div>
                    </div>
                    <div class="flex justify-center mb-12">
                      <div class="inline-flex bg-[#f4f6f8] rounded-full p-1 shadow-lg text-sm duration-buttons-container">
                        {categories[0] && durationsByCategory[categories[0].id]?.map((dur, i) => (
                          <button
                            data-duration-id={dur.id}
                            data-label={dur.duration_label}
                            class={'duration-btn px-4 py-1.5 rounded-full font-semibold transition-all duration-200 ' + (i === 0 ? 'bg-white text-orange-600 shadow-lg' : 'flex items-center gap-1 text-gray-700 hover:text-orange-600')}
                          >
                            <span>{dur.duration_label}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                    <div class="w-full max-w-7xl mx-auto px-8 md:px-12">
                      {categories.map((cat, catIndex) => (
                        durationsByCategory[cat.id]?.map((dur, durIndex) => {
                          const plans = plansByCategoryAndDuration[cat.id]?.[dur.id] || [];
                          const isDefault = catIndex === 0 && durIndex === 0;
                          return (
                            <div
                              class="plan-group"
                              data-category-id={cat.id}
                              data-duration-id={dur.id}
                              data-duration-label={dur.duration_label}
                              style={'display: ' + (isDefault ? '' : 'none')}
                            >
                              <div class="flex justify-center max-w-5xl mx-auto gap-4 flex-wrap mt-8">
                                {plans.map((plan, i) => (
                                  <div class="flex flex-col gap-y-4 items-stretch justify-items-stretch">
                                    <div class="w-[280px] bg-white rounded-xl overflow-clip shadow-[0_2px_20px_rgba(255,115,0,0.2)] flex flex-col">
                                      <div class="mt-2 px-3 py-2 flex items-center relative">
                                        <p class="text-sm font-semibold font-sora">
                                          <span class="text-green-500">{plan.plan_name}</span>
                                        </p>
                                      </div>
                                      <div class="ml-3 pt-1">
                                        <div class="mb-4">
                                          <p>
                                            <span class="text-xl font-semibold font-sora">
                                              {formatPrice(plan.price)}
                                            </span>
                                            {plan.price !== null && (
                                              <span class="font-light text-sm"> {plan.price_suffix || 'per bulan'}</span>
                                            )}
                                          </p>
                                        </div>
                                      </div>
                                      <div class="px-3 flex flex-col justify-between pb-2 pt-2 mt-auto">
                                        <a
                                          href={plan.cta_url || 'https://wa.me/6281234511449?text=Halo%20Maxchat,%20saya%20tertarik%20untuk%20menggunakan%20layanan%20Maxchat'}
                                          target="_blank"
                                          rel="noopener noreferrer"
                                          class="btn primary w-full md rounded-lg font-semibold text-center"
                                          aria-label={plan.cta_text || 'Contact us'}
                                        >
                                          {plan.cta_text || 'Contact us'}
                                        </a>
                                      </div>
                                      <div class="p-4 min-h-[200px]">
                                        <p class="text-sm">{plan.plan_description || ''}</p>
                                      </div>
                                    </div>
                                    <div class="mt-8">
                                      <div id="accordion">
                                        <div>
                                          <button
                                            type="button"
                                            class={'btn accordion w-full base rounded-lg !p-3 md:!px-4 md:!py-6 ' + (i === 0 ? 'active' : '')}
                                          >
                                            <div class="flex justify-between text-left text-base md:text-lg">
                                              Anda akan mendapatkan
                                              <img class="ml-4" src="/_astro/chevron-down.ea170c7f.svg" alt="chevron-icon" />
                                            </div>
                                          </button>
                                          <div class={'transition-all overflow-hidden text-left text-sm text-neutral-500 delay-75 duration-300 hover:text-neutral-500 md:text-base px-4 ' + (i === 0 ? 'h-auto pb-3' : 'max-h-0')}>
                                            {getGroupedFeatures(plan).map(({category, feats}) => (
                                              <div>
                                                <div class="mt-4 mb-2 capitalize"><b>{category}</b></div>
                                                {feats.map(f => (
                                                  <div>
                                                    <div class="flex items-start capitalize">
                                                      <img class="mr-4 mt-[4px] h-[16px] w-[16px]" src="/_astro/check-yellow.f86eb9a2.svg" alt="check-icon" />
                                                      <span>{f.feature_name}</span>
                                                    </div>
                                                  </div>
                                                ))}
                                              </div>
                                            ))}
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          );
                        })
                      ))}
                    </div>
                  </div>

                  <div class="my-6 block md:hidden">
                    <div class="flex justify-center mb-12">
                      <div class="inline-flex bg-[#f4f6f8] rounded-full p-1 shadow-lg text-sm duration-buttons-container">
                        {categories[0] && durationsByCategory[categories[0].id]?.map((dur, i) => (
                          <button
                            data-duration-id={dur.id}
                            data-label={dur.duration_label}
                            class={'duration-btn px-4 py-1.5 rounded-full font-semibold transition-all duration-200 ' + (i === 0 ? 'bg-white text-orange-600 shadow-lg' : 'flex items-center gap-1 text-gray-700 hover:text-orange-600')}
                          >
                            <span>{dur.duration_label}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                    {categories.map((cat, catIndex) => (
                      durationsByCategory[cat.id]?.map((dur, durIndex) => {
                        const plans = plansByCategoryAndDuration[cat.id]?.[dur.id] || [];
                        const isDefault = catIndex === 0 && durIndex === 0;
                        return (
                          <div
                            class="mobile-plan-group"
                            data-category-id={cat.id}
                            data-duration-id={dur.id}
                            data-duration-label={dur.duration_label}
                            style={'display: ' + (isDefault ? '' : 'none')}
                          >
                            <div class="grid grid-cols-1 gap-6 mt-4 px-4">
                              {plans.map(plan => (
                                <div class="flex justify-center">
                                  <div class="w-[280px] bg-white rounded-xl overflow-clip shadow-[0_2px_20px_rgba(255,115,0,0.2)] flex flex-col">
                                    <div class="mt-2 px-3 py-2 flex items-center relative">
                                      <p class="text-sm font-semibold font-sora">
                                        <span class="text-green-500">{plan.plan_name}</span>
                                      </p>
                                    </div>
                                    <div class="ml-3 pt-1">
                                      <div class="mb-4">
                                        <p>
                                          <span class="text-xl font-semibold font-sora">
                                            {formatPrice(plan.price)}
                                          </span>
                                          {plan.price !== null && (
                                            <span class="font-light text-sm"> {plan.price_suffix || 'per bulan'}</span>
                                          )}
                                        </p>
                                      </div>
                                    </div>
                                    <div class="px-3 flex flex-col justify-between pb-2 pt-2 mt-auto">
                                      <a
                                        href={plan.cta_url || 'https://wa.me/6281234511449?text=Halo%20Maxchat,%20saya%20tertarik%20untuk%20menggunakan%20layanan%20Maxchat'}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="btn primary w-full md rounded-lg font-semibold text-center"
                                        aria-label={plan.cta_text || 'Contact us'}
                                      >
                                        {plan.cta_text || 'Contact us'}
                                      </a>
                                    </div>
                                    <div class="p-4 min-h-[200px]">
                                      <p class="text-sm">{plan.plan_description || ''}</p>
                                    </div>
                                  </div>
                                </div>
                              ))}
                            </div>
                            <div class="mt-8 max-w-sm mx-auto">
                              <div id="accordion-mobile">
                                {plans.map(plan => (
                                  <div class="mb-4">
                                    <button
                                      type="button"
                                      class="btn accordion w-full base rounded-lg !p-3 md:!px-4 md:!py-6"
                                    >
                                      <div class="flex justify-between text-left text-base md:text-lg">
                                        Anda akan mendapatkan
                                        <img class="ml-4" src="/_astro/chevron-down.ea170c7f.svg" alt="chevron-icon" />
                                      </div>
                                    </button>
                                    <div class="transition-all overflow-hidden text-left text-sm text-neutral-500 delay-75 duration-300 hover:text-neutral-500 md:text-base px-4 max-h-0">
                                      {getGroupedFeatures(plan).map(({category, feats}) => (
                                        <div>
                                          <div class="mt-4 mb-2 capitalize"><b>{category}</b></div>
                                          {feats.map(f => (
                                            <div>
                                              <div class="flex items-start capitalize">
                                                <img class="mr-4 mt-[4px] h-[16px] w-[16px]" src="/_astro/check-yellow.f86eb9a2.svg" alt="check-icon" />
                                                <span>{f.feature_name}</span>
                                              </div>
                                            </div>
                                          ))}
                                        </div>
                                      ))}
                                    </div>
                                  </div>
                                ))}
                              </div>
                            </div>
                          </div>
                        );
                      })
                    ))}
                  </div>
                </div>
              </section>

              <Fragment set:html={footerHtml} />
            </div>
          </div>
        </div>
      </div>
    </div>

    <script set:html={pricingScriptsStr} />
  </body>
</html>
