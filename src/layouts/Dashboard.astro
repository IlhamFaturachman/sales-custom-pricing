---
interface Props {
  title?: string;
}

const { title = 'Dashboard' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Maxchat</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
</head>
<body>
  <div class="dash-layout">
    <aside class="dash-sidebar">
      <div class="dash-sidebar-header">
        <div class="dash-sidebar-logo">M</div>
        <span class="dash-sidebar-title">Maxchat</span>
      </div>
      <nav class="dash-sidebar-nav">
        <p class="dash-nav-label">Menu</p>
        <a href="/dashboard" class={`dash-nav-item ${currentPath === '/dashboard' ? 'active' : ''}`}>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Dashboard
        </a>
        <a href="/dashboard/create" class={`dash-nav-item ${currentPath === '/dashboard/create' || currentPath.startsWith('/dashboard/edit') ? 'active' : ''}`}>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Buat Pricing
        </a>
      </nav>
      <div class="dash-sidebar-footer">
        <button id="logoutBtn" class="dash-nav-item dash-logout">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
          Logout
        </button>
      </div>
    </aside>
    <main class="dash-main">
      <header class="dash-topbar">
        <div></div>
        <a href="https://maxchat.id" target="_blank" class="dash-topbar-link">maxchat.id</a>
      </header>
      <div class="dash-content">
        <slot />
      </div>
    </main>
  </div>

  <style>
    .dash-layout { display: flex; min-height: 100vh; background: #f9fafb; }
    .dash-sidebar { width: 256px; background: white; border-right: 1px solid #e5e7eb; position: fixed; height: 100vh; overflow-y: auto; display: flex; flex-direction: column; }
    .dash-sidebar-header { padding: 16px 24px; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
    .dash-sidebar-logo { width: 32px; height: 32px; background: linear-gradient(135deg, #f97316, #ef4444); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px; flex-shrink: 0; }
    .dash-sidebar-title { font-size: 18px; font-weight: bold; color: #111827; }
    .dash-sidebar-nav { padding: 24px 16px; flex: 1; }
    .dash-nav-label { font-size: 12px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; padding: 0 12px; margin: 0 0 12px 0; }
    .dash-nav-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 8px; color: #4b5563; text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s; cursor: pointer; background: none; border: none; width: 100%; text-align: left; font-family: inherit; }
    .dash-nav-item:hover { background: #f9fafb; color: #111827; }
    .dash-nav-item.active { background: #fff7ed; color: #c2410c; }
    .dash-nav-item svg { width: 20px; height: 20px; flex-shrink: 0; }
    .dash-sidebar-footer { padding: 16px; border-top: 1px solid #e5e7eb; flex-shrink: 0; }
    .dash-logout { color: #ef4444 !important; }
    .dash-logout:hover { background: #fef2f2 !important; }
    .dash-main { flex: 1; margin-left: 256px; min-height: 100vh; display: flex; flex-direction: column; }
    .dash-topbar { position: sticky; top: 0; z-index: 10; background: white; border-bottom: 1px solid #e5e7eb; padding: 0 32px; height: 64px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .dash-topbar-link { font-size: 14px; color: #6b7280; text-decoration: none; }
    .dash-topbar-link:hover { color: #374151; }
    .dash-content { padding: 32px; flex: 1; }
    @media (max-width: 768px) {
      .dash-sidebar { display: none; }
      .dash-main { margin-left: 0; }
      .dash-content { padding: 16px; }
    }
  </style>

  <style is:global>
    .dash-page-header { display: flex; justify-content: space-between; align-items: center; margin: 0 0 32px 0; }
    .dash-page-title { font-size: 24px; font-weight: bold; color: #111827; margin: 0; }

    .dash-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; transition: all 0.15s; cursor: pointer; border: none; font-family: inherit; }
    .dash-btn-primary { background: #ea580c; color: white; }
    .dash-btn-primary:hover { background: #c2410c; }
    .dash-btn-secondary { background: white; color: #374151; border: 1px solid #d1d5db; }
    .dash-btn-secondary:hover { background: #f9fafb; }
    .dash-btn-danger { background: #ef4444; color: white; }
    .dash-btn-danger:hover { background: #dc2626; }
    .dash-btn-sm { padding: 4px 10px; font-size: 12px; }

    .dash-card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
    .dash-card-header { padding: 20px 24px; border-bottom: 1px solid #e5e7eb; }
    .dash-card-title { font-size: 18px; font-weight: 600; color: #111827; margin: 0; }
    .dash-card-body { padding: 24px; }

    .dash-form-group { margin-bottom: 20px; }
    .dash-form-label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 8px; letter-spacing: 0.02em; }
    .dash-form-input { width: 100%; padding: 10px 14px; border: 1.5px solid #e5e7eb; border-radius: 8px; font-size: 14px; transition: all 0.2s; outline: none; background: white; font-family: inherit; }
    .dash-form-input:focus { border-color: #f97316; box-shadow: 0 0 0 3px rgba(249,115,22,0.1); }
    .dash-form-select { appearance: none; background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e"); background-position: right 10px center; background-repeat: no-repeat; background-size: 20px; padding-right: 36px; }
    .dash-form-textarea { min-height: 80px; resize: vertical; }
    .dash-form-hint { font-size: 12px; color: #9ca3af; margin: 4px 0 0 0; }

    .dash-grid { display: grid; gap: 20px; }
    .dash-grid-2 { grid-template-columns: repeat(2, 1fr); }

    .dash-stats-grid { display: grid; gap: 24px; grid-template-columns: repeat(3, 1fr); margin: 0 0 24px 0; }
    .dash-stat-card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; padding: 24px; }
    .dash-stat-label { font-size: 14px; color: #6b7280; margin: 0 0 8px 0; }
    .dash-stat-value { font-size: 30px; font-weight: bold; color: #111827; margin: 0; }

    .dash-table { width: 100%; border-collapse: collapse; }
    .dash-table th { text-align: left; padding: 12px 24px; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #e5e7eb; background: #f9fafb; }
    .dash-table td { padding: 16px 24px; border-bottom: 1px solid #f3f4f6; font-size: 14px; color: #374151; vertical-align: middle; }
    .dash-table tbody tr:hover { background: #f9fafb; }
    .dash-table tbody tr:last-child td { border-bottom: none; }

    .dash-badge { display: inline-flex; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500; }
    .dash-badge-green { background: #dcfce7; color: #166534; }
    .dash-badge-yellow { background: #fef9c3; color: #854d0e; }
    .dash-badge-gray { background: #f3f4f6; color: #4b5563; }
    .dash-badge-red { background: #fee2e2; color: #991b1b; }

    .dash-actions { display: flex; gap: 8px; }

    .dash-empty-state { text-align: center; padding: 48px 24px; color: #6b7280; }
    .dash-empty-state svg { width: 48px; height: 48px; margin: 0 auto 16px; color: #d1d5db; display: block; }
    .dash-empty-state p { font-size: 14px; margin: 0; }
    .dash-empty-state a { color: #ea580c; text-decoration: none; font-weight: 600; }
    .dash-empty-state a:hover { text-decoration: underline; }

    .dash-client-name { font-weight: 600; color: #111827; }
    .dash-slug-code { font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace; font-size: 13px; background: #f3f4f6; padding: 2px 8px; border-radius: 4px; color: #4b5563; }

    .dash-wizard-progress { display: flex; align-items: flex-start; justify-content: center; margin-bottom: 32px; padding: 0 20px; }
    .dash-wizard-step-indicator { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .dash-wizard-step-number { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600; background: #f3f4f6; color: #9ca3af; transition: all 0.3s; }
    .dash-wizard-step-number.active { background: #ea580c; color: white; box-shadow: 0 0 0 4px rgba(234,88,12,0.15); }
    .dash-wizard-step-number.completed { background: #16a34a; color: white; }
    .dash-wizard-step-label { font-size: 12px; color: #9ca3af; font-weight: 500; white-space: nowrap; }
    .dash-wizard-step-label.active { color: #ea580c; font-weight: 600; }
    .dash-wizard-connector { width: 60px; height: 2px; background: #e5e7eb; margin-top: 17px; transition: background 0.3s; }
    .dash-wizard-connector.completed { background: #16a34a; }

    .dash-text-gray { color: #6b7280; }
    .dash-mb-4 { margin-bottom: 16px; }
    .dash-mt-4 { margin-top: 16px; }

    @media (max-width: 768px) {
      .dash-stats-grid { grid-template-columns: 1fr; }
      .dash-grid-2 { grid-template-columns: 1fr; }
      .dash-table { font-size: 13px; }
      .dash-table th, .dash-table td { padding: 12px 16px; }
      .dash-actions { flex-direction: column; gap: 4px; }
      .dash-wizard-progress { overflow-x: auto; }
      .dash-wizard-connector { width: 30px; }
    }
  </style>

  <script>
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
      if (confirm('Yakin ingin logout?')) {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/login';
      }
    });
  </script>
</body>
</html>